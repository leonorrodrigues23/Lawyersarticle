          <span><strong>{testingStats.expertsInvolved}</strong> experts involved</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TOP 3 FEATURED CARDS -->
  <section class="top-picks-section">
    <div class="top-picks-container">
      <div class="top-picks-grid">
        {/* Second Place - Left */}

const methodology = [
  { number: "01", title: "Range of Services", description: "We evaluate the breadth and depth of legal services offered—from business formation and document creation to attorney consultations and ongoing legal support." },
  { number: "02", title: "Pricing & Value", description: "We compare pricing models across platforms, analyzing per-service costs, subscription plans, and hidden fees to determine which services deliver genuine value for different usage levels." },
  { number: "03", title: "Attorney Quality & Access", description: "We assess attorney vetting processes, availability, specialization coverage, and consultation quality to ensure users get competent legal guidance." },
  { number: "04", title: "User Experience & Trust", description: "We analyze platform usability, document accuracy, customer support responsiveness, satisfaction guarantees, and verified user reviews." }
];

const criteria = [
  { icon: "shield", color: "green", title: "Service Breadth", description: "Comprehensive platforms covering business formation, estate planning, IP protection, and more earn higher marks." },
  { icon: "dollar", color: "blue", title: "Transparent Pricing", description: "Clear, upfront pricing with no hidden fees. The best platforms let you know exactly what you'll pay before committing." },
  { icon: "users", color: "purple", title: "Attorney Access", description: "On-demand access to licensed attorneys for consultations, document review, and legal advice when DIY isn't enough." },
  { icon: "document", color: "orange", title: "Document Accuracy", description: "Legally valid, state-specific documents that are regularly updated to reflect current laws and regulations." }
];

const faqs = [
  {
    question: "When do I need an online legal service vs. a traditional lawyer?",
    answer: "Online legal services work best for routine matters like LLC formation, simple wills, trademark filings, and standard contracts. For complex litigation, criminal defense, or high-stakes disputes, you'll want a traditional attorney. Many online platforms can help you determine whether your situation requires full legal representation."
  },
  {
    question: "Are documents created by online legal services legally valid?",
    answer: "Yes. Documents created through reputable online legal platforms are legally valid when properly executed. These platforms use attorney-drafted templates that comply with state and federal requirements. However, for complex situations, having an attorney review the document adds an extra layer of protection."
  },
  {
    question: "How much can I save using online legal services?",
    answer: "Significantly. A simple LLC formation that might cost $1,000-$2,500 with a traditional attorney can be done for $0-$300 online plus state fees. A basic will costs $300-$1,000 with an attorney versus $50-$200 online. Ongoing legal subscriptions at $40/month replace hourly consultations that typically run $200-$500/hour."
  },
  {
    question: "Is my information secure on these platforms?",
    answer: "Reputable online legal platforms use bank-level encryption, secure data storage, and strict privacy policies. Most are SOC 2 compliant and undergo regular security audits. Always verify a platform's security certifications before submitting sensitive information."
  },
  {
    question: "Can I form an LLC through an online legal service?",
    answer: "Absolutely. LLC formation is one of the most popular services offered by online legal platforms. Most can handle the entire process—from filing articles of organization to obtaining an EIN and creating an operating agreement—in just a few business days."
  },
  {
    question: "What if I'm not satisfied with the service?",
    answer: "Most reputable platforms offer satisfaction guarantees or money-back policies. LegalZoom, for example, offers a 60-day satisfaction guarantee. Always check the refund policy before purchasing, and keep records of any issues for your claim."
  }
];

function getStarRating(rating: number) {
  const fullStars = Math.floor(rating);
  const partialFill = (rating - fullStars) * 100;
  const emptyStars = 5 - Math.ceil(rating);
  return { fullStars, partialFill, emptyStars, hasPartial: partialFill > 0 };
}
---

<MainLayout title={articleConfig.title} description={articleConfig.subtitle}>
  
  <!-- HERO SECTION -->
  <section class="hero-section">
    <div class="hero-container">
      <div class="hero-content">
        <div class="hero-meta">
          <span class="category-tag">{articleConfig.category}</span>
          <span class="separator">&bull;</span>
          <span class="reading-time">{articleConfig.readingTime}</span>
        </div>
        <h1 class="hero-title">{articleConfig.title}</h1>
        <p class="hero-subtitle">{articleConfig.subtitle}</p>
        <div class="author-card">
          <img src={author.image} alt={author.name} class="author-image" onerror="this.src='https://ui-avatars.com/api/?name=JM&background=1a365d&color=fff&size=96'" />
          <div class="author-details">
            <div class="author-name">{author.name}</div>
            <div class="author-title">{author.title}</div>
          </div>
          <div class="author-date">
            <span>Updated</span>
            <strong>{testingStats.lastUpdated}</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BADGES -->
  <section class="trust-section">
    <div class="trust-container">
      <div class="trust-badges">
        <div class="trust-badge">
          <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span><strong>{testingStats.productsTested}</strong> platforms tested</span>
        </div>
        <div class="trust-badge">

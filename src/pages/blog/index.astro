---
import MainLayout from '../../layouts/MainLayout.astro';
import { SITE_BRAND } from '../../consts';

const blogPosts = [
  {
    title: "LegalZoom vs Rocket Lawyer: Complete 2026 Comparison Guide",
    description: "A head-to-head comparison of the two biggest online legal platforms. Find out which is better for your specific legal needs and budget.",
    slug: "legalzoom-vs-rocket-lawyer",
    date: "Mar 3, 2026",
    readingTime: "12 min read",
    category: "Comparisons",
    image: "https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=600&h=400&fit=crop"
  },
  {
    title: "How to Form an LLC Online: Step-by-Step Guide for 2026",
    description: "Everything you need to know about forming an LLC online, from choosing a state to getting your EIN and operating agreement.",
    slug: "how-to-form-llc-online",
    date: "Mar 1, 2026",
    readingTime: "14 min read",
    category: "Business Formation",
    image: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&h=400&fit=crop"
  },
  {
    title: "Do I Need a Lawyer? When DIY Legal Services Are (and Aren't) Enough",
    description: "A practical guide to knowing when you can handle legal matters yourself and when you should hire a professional attorney.",
    slug: "when-do-i-need-a-lawyer",
    date: "Feb 27, 2026",
    readingTime: "10 min read",
    category: "Legal Basics",
    image: "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=600&h=400&fit=crop"
  },
  {
    title: "Online Will Makers: Are They Worth It in 2026?",
    description: "We tested the top online will-making platforms and compared them to traditional estate planning attorneys. Here's what we found.",
    slug: "online-will-makers-review",
    date: "Feb 24, 2026",
    readingTime: "11 min read",
    category: "Estate Planning",
    image: "https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=600&h=400&fit=crop"
  },
  {
    title: "How to Trademark a Business Name: Complete Online Guide",
    description: "Learn how to protect your brand with a trademark filing through an online legal service, step by step.",
    slug: "how-to-trademark-business-name",
    date: "Feb 20, 2026",
    readingTime: "9 min read",
    category: "Intellectual Property",
    image: "https://images.unsplash.com/photo-1516321497487-e288fb19713f?w=600&h=400&fit=crop"
  },
  {
    title: "Best Legal Services for Small Businesses in 2026",
    description: "From contracts to compliance, discover the best online legal platforms designed specifically for small business owners.",
    slug: "best-legal-services-small-business",
    date: "Feb 17, 2026",
    readingTime: "13 min read",
    category: "Small Business",
    image: "https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=600&h=400&fit=crop"
  },
  {
    title: "Understanding Power of Attorney: Types, Costs, and How to Get One",
    description: "Everything you need to know about powers of attorney—who needs one, what types exist, and how to create one online.",
    slug: "power-of-attorney-guide",
    date: "Feb 14, 2026",
    readingTime: "10 min read",
    category: "Estate Planning",
    image: "https://images.unsplash.com/photo-1554224154-26032ffc0d07?w=600&h=400&fit=crop"
  },
  {
    title: "LLC vs S-Corp vs C-Corp: Choosing the Right Business Structure",
    description: "Understand the key differences between business entity types so you can make the right choice for your venture.",
    slug: "llc-vs-scorp-vs-ccorp",
    date: "Feb 10, 2026",
    readingTime: "12 min read",
    category: "Business Formation",
    image: "https://images.unsplash.com/photo-1591474200742-8e512e6f98f8?w=600&h=400&fit=crop"
  },
  {
    title: "Freelancer Legal Essentials: Contracts, LLCs, and Taxes",
    description: "A comprehensive legal guide for freelancers covering the documents and protections every independent worker needs.",
    slug: "freelancer-legal-essentials",
    date: "Feb 6, 2026",
    readingTime: "11 min read",
    category: "Freelancing",
    image: "https://images.unsplash.com/photo-1434030216411-0b793f4b4173?w=600&h=400&fit=crop"
  },
  {
    title: "10 Legal Mistakes New Business Owners Make (And How to Avoid Them)",
    description: "Don't let these common legal pitfalls derail your business. Learn what to avoid and how online services can help.",
    slug: "legal-mistakes-new-business-owners",
    date: "Feb 2, 2026",
    readingTime: "10 min read",
    category: "Tips & Advice",
    image: "https://images.unsplash.com/photo-1586473219010-2ffc57b0d282?w=600&h=400&fit=crop"
  }
];
---

<MainLayout title="Legal Services Blog" description="Expert legal guides, tips, and advice to help you navigate online legal services and protect your personal and business interests.">
  
  <section class="blog-hero">
    <div class="blog-hero-container">
      <h1 class="blog-hero-title">Legal Services Blog</h1>
      <p class="blog-hero-subtitle">Expert guides, tips, and advice to help you navigate online legal services and protect your personal and business interests.</p>
    </div>
  </section>

  <section class="featured-section">
    <div class="featured-container">
      <a href={`/blog/${blogPosts[0].slug}`} class="featured-card">
        <div class="featured-image">
          <img src={blogPosts[0].image} alt={blogPosts[0].title} loading="lazy" />
        </div>
        <div class="featured-content">
          <div class="featured-badge">Featured Article</div>
          <span class="featured-category">{blogPosts[0].category}</span>
          <h2 class="featured-title">{blogPosts[0].title}</h2>
          <p class="featured-description">{blogPosts[0].description}</p>
          <div class="featured-meta">
            <span>{blogPosts[0].date}</span>
            <span>&bull;</span>
            <span>{blogPosts[0].readingTime}</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <section class="posts-section">
    <div class="posts-container">
      <h2 class="posts-heading">Latest Articles</h2>
      <div class="posts-grid">
        {blogPosts.slice(1).map((post) => (
          <a href={`/blog/${post.slug}`} class="post-card">
            <div class="post-image">
              <img src={post.image} alt={post.title} loading="lazy" />
            </div>
            <div class="post-content">
              <span class="post-category">{post.category}</span>
              <h3 class="post-title">{post.title}</h3>
              <p class="post-description">{post.description}</p>
              <div class="post-meta">
                <span>{post.date}</span>
                <span>&bull;</span>
                <span>{post.readingTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-container">
      <h2 class="cta-title">Ready to Find the Right Legal Service?</h2>
      <p class="cta-text">Compare the best online legal platforms and get the help you need in minutes.</p>
      <a href="/" class="cta-button">Compare Top Legal Services &rarr;</a>
    </div>
  </section>

</MainLayout>

<style>
  .blog-hero { background: linear-gradient(180deg, #F7F8FA 0%, #FFFFFF 100%); padding: 3rem 0; border-bottom: 1px solid #E5E7EB; }
  .blog-hero-container { max-width: 800px; margin: 0 auto; padding: 0 1.5rem; text-align: center; }
  .blog-hero-title { font-family: 'Sora', sans-serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: #162433; margin-bottom: 1rem; }
  .blog-hero-subtitle { font-size: 1.125rem; color: #4B5563; line-height: 1.6; max-width: 600px; margin: 0 auto; }
  .featured-section { padding: 3rem 0; background: white; }
  .featured-container { max-width: 1000px; margin: 0 auto; padding: 0 1.5rem; }
  .featured-card { display: grid; grid-template-columns: 280px 1fr; gap: 2rem; background: white; border: 1px solid #E2E8F0; border-radius: 20px; overflow: hidden; text-decoration: none; transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .featured-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.12); }
  .featured-image { min-height: 280px; overflow: hidden; }
  .featured-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
  .featured-card:hover .featured-image img { transform: scale(1.05); }
  .featured-content { padding: 2rem 2rem 2rem 0; display: flex; flex-direction: column; justify-content: center; }
  .featured-badge { display: inline-block; background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%); color: white; font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.375rem 0.75rem; border-radius: 20px; margin-bottom: 1rem; align-self: flex-start; }
  .featured-category { display: inline-block; background: #EBF5FF; color: #1a365d; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.25rem 0.5rem; border-radius: 4px; margin-bottom: 0.75rem; align-self: flex-start; }
  .featured-title { font-family: 'Sora', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 700; color: #162433; margin-bottom: 0.75rem; line-height: 1.3; }
  .featured-description { font-size: 0.9375rem; color: #4B5563; line-height: 1.7; margin-bottom: 1rem; }
  .featured-meta { display: flex; gap: 0.5rem; font-size: 0.8125rem; color: #68727C; }
  @media (max-width: 768px) { .featured-card { grid-template-columns: 1fr; } .featured-image { min-height: 180px; } .featured-content { padding: 0 1.5rem 1.5rem; } }
  .posts-section { padding: 0 0 4rem; background: white; }
  .posts-container { max-width: 1000px; margin: 0 auto; padding: 0 1.5rem; }
  .posts-heading { font-family: 'Sora', sans-serif; font-size: 1.5rem; font-weight: 700; color: #162433; margin-bottom: 2rem; padding-bottom: 0.75rem; border-bottom: 3px solid #E5E7EB; }
  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  @media (max-width: 900px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .posts-grid { grid-template-columns: 1fr; } }
  .post-card { display: flex; flex-direction: column; background: #FFFFFF; border: 1px solid #E2E8F0; border-radius: 16px; overflow: hidden; text-decoration: none; transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .post-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
  .post-image { height: 160px; overflow: hidden; }
  .post-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
  .post-card:hover .post-image img { transform: scale(1.08); }
  .post-content { padding: 1.25rem; display: flex; flex-direction: column; flex-grow: 1; }
  .post-category { display: inline-block; background: #EBF5FF; color: #1a365d; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.25rem 0.5rem; border-radius: 4px; margin-bottom: 0.75rem; align-self: flex-start; }
  .post-title { font-family: 'Sora', sans-serif; font-size: 1rem; font-weight: 700; color: #162433; margin-bottom: 0.5rem; line-height: 1.4; }
  .post-description { font-size: 0.8125rem; color: #68727C; line-height: 1.6; margin-bottom: 1rem; flex-grow: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .post-meta { display: flex; gap: 0.5rem; font-size: 0.75rem; color: #9CA3AF; }
  .cta-section { background: #F7F8FA; padding: 4rem 0; border-top: 1px solid #E5E7EB; }
  .cta-container { max-width: 600px; margin: 0 auto; padding: 0 1.5rem; text-align: center; }
  .cta-title { font-family: 'Sora', sans-serif; font-size: 1.75rem; font-weight: 700; color: #162433; margin-bottom: 1rem; }
  .cta-text { font-size: 1rem; color: #4B5563; margin-bottom: 1.5rem; }
  .cta-button { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 2rem; background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%); color: white; font-weight: 700; font-size: 1rem; text-decoration: none; border-radius: 10px; transition: all 0.2s ease; }
  .cta-button:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(34, 197, 94, 0.4); }
</style>
